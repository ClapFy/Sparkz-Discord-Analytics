# Bot (Railway service: bot, root directory bot/)
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
CLICKHOUSE_HOST=
CLICKHOUSE_PORT=8443
CLICKHOUSE_USER=
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=sparkzanalytics
CLICKHOUSE_SECURE=true
LOG_LEVEL=info
CH_BATCH_MS=2000
CH_BATCH_MAX_ROWS=500

# Web dashboard (Railway service: web, root directory web/)
# DISCORD_GUILD_ID must match the bot target guild (for query scoping).
DISCORD_GUILD_ID=
CLICKHOUSE_HOST=
CLICKHOUSE_PORT=8443
CLICKHOUSE_USER=
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=sparkzanalytics
CLICKHOUSE_SECURE=true
ADMIN_USERNAME=
ADMIN_PASSWORD=
# Session cookie signing (use one; min 32 characters)
NEXTAUTH_SECRET=
# SESSION_SECRET=
SKIP_SCHEMA_ENSURE=false

# Optional: Bearer token for machine / agent diagnostics (min 32 chars).
# GET /api/internal/diagnostics with header Authorization: Bearer <token>
# Browser helper (same origin): /internal/diag
# Set only in your hosting provider secrets; deploy web via GitHub-connected CI.
# Railway: can set via Cursor Railway MCP (see devtools/mcp/OPERATOR_RUNBOOK.md).
INTERNAL_DIAG_TOKEN=
